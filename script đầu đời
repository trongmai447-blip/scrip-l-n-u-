-- Vòng lặp tối ưu hóa AI thực thi đặt khối liên tục
task.spawn(function()
    while task.wait(0.08) do -- Điều chỉnh độ trễ tránh lag thiết bị di động
        if HackConfig.AIAutoBuild then
            local remote = AIScanForRemote()
            if remote then
                pcall(function()
                    local Character = LocalPlayer.Character
                    local Root = Character and Character:FindFirstChild("HumanoidRootPart")
                    if Root then
                        -- Xác định vị trí mục tiêu đặt khối (ngay trước mặt và dưới chân một chút)
                        local TargetPos = Root.Position + (Root.CFrame.LookVector * 6) - Vector3.new(0, 1.2, 0)
                        
                        -- KIỂU 1: Nếu AI đã hít được thông tin đối số từ game
                        if AIArgFormat and AICapturedArgs then
                            if AIArgFormat == "Vector3_First" then
                                remote:FireServer(TargetPos, AICapturedArgs[2] or "Normal")
                            elseif AIArgFormat == "CFrame_First" then
                                remote:FireServer(CFrame.new(TargetPos), AICapturedArgs[2] or "Normal")
                            elseif AIArgFormat == "String_First" then
                                remote:FireServer(AICapturedArgs[1] or "Normal", TargetPos)
                            elseif AIArgFormat == "Table_Structure" then
                                -- Nếu game dùng bảng mã hóa dữ liệu phức tạp, AI tự nhân bản bảng mẫu và thay tọa độ vào
                                local customTable = game:GetService("HttpService"):JSONDecode(game:GetService("HttpService"):JSONEncode(AICapturedArgs[1]))
                                for k, val in pairs(customTable) do
                                    if typeof(val) == "Vector3" then customTable[k] = TargetPos
                                    elseif typeof(val) == "CFrame" then customTable[k] = CFrame.new(TargetPos) end
                                end
                                remote:FireServer(customTable)
                            end
                        else
                            -- KIỂU 2: ĐOÁN MÒ THÔNG MINH (Brute-Force Fallback nếu chưa có ai đặt khối để bắt gói tin)
                            -- Tự động gửi thử cả 3 cấu trúc phổ biến nhất quả đất của Roblox Sandbox
                            remote:FireServer(TargetPos, "Normal")
                            remote:FireServer(CFrame.new(TargetPos), "Normal")
                            remote:FireServer("Normal", TargetPos)
                            LogLabel.Text = "🤖 AI: Đang ép mã đặt khối (Đoán mò)..."
                        end
                    end
                end)
            else
                LogLabel.Text = "❌ AI: Không tìm thấy Remote xây dựng nào!"
                LogLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
        end
    end
end)

