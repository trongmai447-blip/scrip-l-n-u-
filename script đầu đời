local function ArrayBuild(mode)
    if not _G.IsReady then _G.UpdateStatus("❌ Lỗi: Chưa ghi âm khối!", Color3.fromRGB(255,50,50)) return end
    local sCF = _G.GhostBlock.CFrame; local hX, hY, hZ = _G.Hitbox.X, _G.Hitbox.Y, _G.Hitbox.Z
    task.spawn(function()
        if mode == "Wall" then
            for y = 0, 3 do for x = -2, 2 do PlaceBlock(sCF * CFrame.new(x*hX, y*hY, 0)); task.wait(0.1) end end
        elseif mode == "Floor" then
            for z = -2, 2 do for x = -2, 2 do PlaceBlock(sCF * CFrame.new(x*hX, 0, z*hZ)); task.wait(0.1) end end
        elseif mode == "Pillar" then
            for y = 0, 4 do PlaceBlock(sCF * CFrame.new(0, y*hY, 0)); task.wait(0.1) end
        end
    end)
end

