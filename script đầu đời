-- Hàm tạo nút +/- thay cho slider để chuẩn xác 100% trên điện thoại
local function CreateAdjuster(name, yPos, targetVar, step, isVector, axis)
    local Lbl = Instance.new("TextLabel", AdjUI)
    Lbl.Size = UDim2.new(0.4, 0, 0, 25)
    Lbl.Position = UDim2.new(0.05, 0, 0, yPos)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = name
    Lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    Lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local BtnMinus = Instance.new("TextButton", AdjUI)
    BtnMinus.Size = UDim2.new(0.1, 0, 0, 25)
    BtnMinus.Position = UDim2.new(0.5, 0, 0, yPos)
    BtnMinus.Text = "-"
    
    local ValLbl = Instance.new("TextLabel", AdjUI)
    ValLbl.Size = UDim2.new(0.2, 0, 0, 25)
    ValLbl.Position = UDim2.new(0.65, 0, 0, yPos)
    ValLbl.Text = "0"
    
    local BtnPlus = Instance.new("TextButton", AdjUI)
    BtnPlus.Size = UDim2.new(0.1, 0, 0, 25)
    BtnPlus.Position = UDim2.new(0.85, 0, 0, yPos)
    BtnPlus.Text = "+"

    local function UpdateVal()
        if isVector then ValLbl.Text = tostring(_G[targetVar][axis]) else ValLbl.Text = tostring(_G[targetVar]) end
    end
    UpdateVal()

    BtnMinus.MouseButton1Click:Connect(function()
        if isVector then
            local cv = _G[targetVar]
            if axis=="X" then _G[targetVar] = Vector3.new(cv.X-step, cv.Y, cv.Z)
            elseif axis=="Y" then _G[targetVar] = Vector3.new(cv.X, cv.Y-step, cv.Z)
            else _G[targetVar] = Vector3.new(cv.X, cv.Y, cv.Z-step) end
        else _G[targetVar] = _G[targetVar] - step end
        UpdateVal()
    end)
    
    BtnPlus.MouseButton1Click:Connect(function()
        if isVector then
            local cv = _G[targetVar]
            if axis=="X" then _G[targetVar] = Vector3.new(cv.X+step, cv.Y, cv.Z)
            elseif axis=="Y" then _G[targetVar] = Vector3.new(cv.X, cv.Y+step, cv.Z)
            else _G[targetVar] = Vector3.new(cv.X, cv.Y, cv.Z+step) end
        else _G[targetVar] = _G[targetVar] + step end
        UpdateVal()
    end)
end

