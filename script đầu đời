-- =========================================================
-- 🧠 AI HACK VÀO GÓI TIN & TỰ ĐỘNG CHỈNH CFRAME
-- =========================================================
local function ApplyCFrameAndRotation(args, targetCFrame)
    local newArgs = {}
    for k, v in pairs(args) do
        if typeof(v) == "CFrame" or typeof(v) == "Vector3" then
            newArgs[k] = targetCFrame -- Chèn CFrame đã xoay và chỉnh tọa độ vào
        elseif type(v) == "table" then
            local s, res = pcall(function() return ApplyCFrameAndRotation(v, targetCFrame) end)
            newArgs[k] = s and res or v
        else
            newArgs[k] = v 
        end
    end
    return newArgs
end

pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if _G.IsRecording and not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
            if not tostring(self.Name):match("Mouse") and not tostring(self.Name):match("Camera") then
                _G.TargetRemote = self
                _G.TargetArgs = args
                _G.IsRecording = false
                _G.IsReady = true
                print("[V14] Tóm gọn Remote! Đã nạp dữ liệu kiến trúc.")
            end
        end
        return oldNamecall(self, ...)
    end)
end)

-- Hàm gửi khối lên Server
local function PlaceBlock(targetCFrame)
    if not _G.IsReady or not _G.TargetRemote then return end
    local clonedArgs = ApplyCFrameAndRotation(_G.TargetArgs, targetCFrame)
    if _G.TargetRemote:IsA("RemoteEvent") then
        _G.TargetRemote:FireServer(unpack(clonedArgs))
    else
        task.spawn(function() _G.TargetRemote:InvokeServer(unpack(clonedArgs)) end)
    end
end

