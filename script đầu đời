local function generateGrid()
    if not isBuildOn then return end
    clearPreview()
    local folder = create("Folder", {Name = "BuildGenius_Grid"}, workspace)
    Mouse.TargetFilter = folder
    local xLimit = (buildType == "CỘT") and 1 or sizeX
    local yLimit = (buildType == "SÀN" or buildType == "TRẦN") and 1 or sizeY
    local zLimit = (buildType == "TƯỜNG" or buildType == "CỘT") and 1 or sizeZ

    for x = 1, xLimit do
        for y = 1, yLimit do
            for z = 1, zLimit do
                local part = create("Part", {Size = Vector3.new(BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE), Anchored = true, CanCollide = false, Transparency = 0.5, Color = Color3.fromRGB(0, 150, 255), Material = Enum.Material.Neon}, folder)
                part:SetAttribute("RelX", (x - 1) * BLOCK_SIZE); part:SetAttribute("RelY", (y - 1) * BLOCK_SIZE); part:SetAttribute("RelZ", (z - 1) * BLOCK_SIZE)
                
                -- Mặt Trước (Front) màu đỏ rực
                local guiFront = create("SurfaceGui", {Face = Enum.NormalId.Front, AlwaysOnTop = true}, part)
                create("Frame", {Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(255, 0, 0), BackgroundTransparency = 0.2}, guiFront)
                
                -- Mặt Sau (Back) màu đỏ rực để định hình khối đặc biệt
                local guiBack = create("SurfaceGui", {Face = Enum.NormalId.Back, AlwaysOnTop = true}, part)
                create("Frame", {Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(255, 0, 0), BackgroundTransparency = 0.2}, guiBack)
                
                create("SelectionBox", {Adornee = part, LineThickness = 0.02, Color3 = Color3.fromRGB(255, 255, 255)}, part)
            end
        end
    end
    buildPreviewFolder = folder
end

local function updatePosition()
    if not buildPreviewFolder or not buildPreviewFolder:IsDescendantOf(workspace) then return end
    local targetCFrame
    if not isLocked then
        if Mouse.Target and Mouse.Target:IsA("BasePart") then
            local hitPos = Mouse.Hit.Position
            targetCFrame = CFrame.new(math.floor(hitPos.X / BLOCK_SIZE + 0.5) * BLOCK_SIZE, math.floor(hitPos.Y / BLOCK_SIZE + 0.5) * BLOCK_SIZE, math.floor(hitPos.Z / BLOCK_SIZE + 0.5) * BLOCK_SIZE) * CFrame.Angles(0, math.rad(rotationAngle), 0)
            baseCFrame = targetCFrame
        else
            targetCFrame = Camera.CFrame * CFrame.new(0, 0, -20) * CFrame.Angles(0, math.rad(rotationAngle), 0)
            baseCFrame = targetCFrame
        end
    else
        targetCFrame = baseCFrame and (baseCFrame * CFrame.new(offsetX * BLOCK_SIZE, offsetY * BLOCK_SIZE, offsetZ * BLOCK_SIZE)) or CFrame.new(0,0,0)
    end

    local finalPos = targetCFrame.Position
    if finalPos.Y > maxBuildingHeight then finalPos = Vector3.new(finalPos.X, maxBuildingHeight, finalPos.Z) end
    if currentPlot then
        local pSize, pPos = currentPlot.Size, currentPlot.Position
        local minX, maxX = pPos.X - pSize.X/2 + BLOCK_SIZE, pPos.X + pSize.X/2 - BLOCK_SIZE
        local minZ, maxZ = pPos.Z - pSize.Z/2 + BLOCK_SIZE, pPos.Z + pSize.Z/2 - BLOCK_SIZE
        finalPos = Vector3.new(math.clamp(finalPos.X, minX, maxX), finalPos.Y, math.clamp(finalPos.Z, minZ, maxZ))
    end
    targetCFrame = (targetCFrame - targetCFrame.Position) + finalPos

    for _, part in ipairs(buildPreviewFolder:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "ClientPlacedBlock" then
            part.CFrame = targetCFrame * CFrame.new(part:GetAttribute("RelX"), part:GetAttribute("RelY"), part:GetAttribute("RelZ"))
        end
    end
end

