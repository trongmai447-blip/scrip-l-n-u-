        task.spawn(function() pcall(gameBuildRemote.InvokeServer, gameBuildRemote, currentScannedName, targetCFrame, currentScannedCategory) end)
    end
end

local function createSlider(parent, labelText, yPos, callback)
    local container = create("Frame", {Size = UDim2.new(1, -20, 0, 40), Position = UDim2.new(0, 10, 0, yPos), BackgroundTransparency = 1}, parent)
    local label = create("TextLabel", {Size = UDim2.new(1, 0, 0, 15), Text = "WAIT...", TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.SourceSansBold, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1}, container)
    local track = create("Frame", {Size = UDim2.new(1, 0, 0, 6), Position = UDim2.new(0, 0, 0, 22), BackgroundColor3 = Color3.fromRGB(50, 50, 50)}, container)
    create("UICorner", {}, track)
    local knob = create("TextButton", {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(0.5, -8, 0, -5), BackgroundColor3 = Color3.fromRGB(0, 255, 150), Text = ""}, track)
    create("UICorner", {CornerRadius = UDim.new(1, 0)}, knob)

    local currentRatio, dragging = 0.5, false
    local function updateVisuals()
        knob.Position = UDim2.new(currentRatio, -8, 0, -5)
        if adjustMode == "SIZE" then
            local val = math.round(1 + currentRatio * 14)
            label.Text = "KÍCH THƯỚC VÙNG " .. labelText .. ": " .. val; callback(val)
        else
            local val = math.round(-15 + currentRatio * 30)
            label.Text = "TỌA ĐỘ LỆCH " .. labelText .. ": " .. (val > 0 and "+" .. val or val); callback(val)
        end
    end

    knob.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local trackLeft, trackWidth = track.AbsolutePosition.X, track.AbsoluteSize.X
            if trackWidth > 0 then currentRatio = math.clamp((UserInputService:GetMouseLocation().X - trackLeft) / trackWidth, 0, 1); updateVisuals() end
        end
    end)
    return function(forced) currentRatio = forced or 0.5; updateVisuals() end
end

