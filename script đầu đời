-- 🛡️ BỘ QUÉT LỖI F9 VÀ TỰ KHẮC PHỤC (AUTO-DIAGNOSTIC ENGINE)
-- =========================================================
local function F9_DiagnosticAndFix(errorCode, context)
    -- In ra F9 Console với định dạng siêu chuẩn
    warn("=========================================")
    warn("[BUILD GENIUS v13] ⚠️ PHÁT HIỆN LỖI LÚC: " .. context)
    print("Mã lỗi gốc: " .. tostring(errorCode))
    
    -- AI PHÂN TÍCH VÀ TỰ FIX
    if string.find(errorCode, "attempt to call a nil value") or string.find(errorCode, "destroyed") then
        print("🔍 PHÂN TÍCH: Game đã xóa hoặc đổi tên Remote để chống hack!")
        print("🛠️ TỰ KHẮC PHỤC: Xóa bộ nhớ Remote cũ. Dừng Auto-Build để bảo vệ game không bị văng.")
        _G.TargetRemote = nil
        _G.IsReady = false
        if _G.UpdateLog then _G.UpdateLog("❌ GAME ĐỔI REMOTE! Hãy Bấm Ghi Âm Lại!", Color3.fromRGB(255, 50, 50)) end
        if _G.ToggleAutoBuild then _G.ToggleAutoBuild(false) end

    elseif string.find(errorCode, "timeout") or string.find(errorCode, "exhausted") then
        print("🔍 PHÂN TÍCH: Server đang bị quá tải (Lag) hoặc Script chạy quá nhanh!")
        print("🛠️ TỰ KHẮC PHỤC: Tự động giảm tốc độ Auto-Build xuống để Server kịp xử lý.")
        _G.BuildDelay = 0.3 -- Giảm tốc độ đặt khối
        
    elseif string.find(errorCode, "Vector3") or string.find(errorCode, "CFrame") then
        print("🔍 PHÂN TÍCH: Lỗi tính toán tọa độ (Toán học). Nhân vật có thể đang rơi ngoài map.")
        print("🛠️ TỰ KHẮC PHỤC: Tạm ngưng đặt khối, chờ nhân vật ổn định lại.")
        task.wait(1)
        
    else
        print("🔍 PHÂN TÍCH: Lỗi hệ thống mã hóa bảng (Table) của game.")
        print("🛠️ TỰ KHẮC PHỤC: Bỏ qua chu kỳ này, tiếp tục vòng lặp sau.")
    end
    warn("=========================================")
end

-- === HÀM DEEP CLONE (NHÂN BẢN SÂU KÈM BẢO VỆ LỖI) ===
local function ReplaceCoordinatesInArgs(args, newPos)
    local newArgs = {}
    for k, v in pairs(args) do
        if typeof(v) == "Vector3" then
            newArgs[k] = newPos
        elseif typeof(v) == "CFrame" then
            newArgs[k] = CFrame.new(newPos)
        elseif type(v) == "table" then
            -- Chống lặp đệ quy vô hạn (Cyclic Table)
            local success, result = pcall(function()
                return ReplaceCoordinatesInArgs(v, newPos)
            end)
            if success then
                newArgs[k] = result
            else
                F9_DiagnosticAndFix(result, "Đang nhân bản Bảng dữ liệu")
                newArgs[k] = v
            end
        else
            newArgs[k] = v 
        end
    end
    return newArgs
end

-- === HỆ THỐNG MÓC NỐI GÓI TIN (HOOKMETAMETHOD) ===
pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if _G.IsRecording and not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
            local remoteName = tostring(self.Name)
            local isSpam = remoteName:match("Mouse") or remoteName:match("Camera") or remoteName:match("Move") or remoteName:match("Character")
            
            if not isSpam then
                local success, err = pcall(function()
                    _G.TargetRemote = self
                    _G.TargetArgs = args
                    _G.IsRecording = false
                    _G.IsReady = true
                    if _G.UpdateLog then _G.UpdateLog("🟢 ĐÃ TÓM GỌN REMOTE! Bật Auto đi!", Color3.fromRGB(0, 255, 100)) end
                    print("[BUILD GENIUS F9] ✅ Bắt thành công dữ liệu từ: " .. remoteName)
                end)
                
                if not success then F9_DiagnosticAndFix(err, "Trong lúc Ghi âm Packet") end
            end
        end
        return oldNamecall(self, ...)
    end)
end)

