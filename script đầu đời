local function ArrayBuild(mode)
    if not _G.IsReady then return end
    local startCFrame = GhostBlock.CFrame
    local hX, hY, hZ = _G.Hitbox.X, _G.Hitbox.Y, _G.Hitbox.Z
    
    task.spawn(function()
        if mode == "Wall" then
            -- Xây Tường: Rộng 5 khối, Cao 4 khối
            for y = 0, 3 do
                for x = -2, 2 do
                    PlaceBlock(startCFrame * CFrame.new(x * hX, y * hY, 0))
                    task.wait(0.1) -- Tránh lag Server
                end
            end
        elseif mode == "Floor" then
            -- Xây Sàn/Mái: Rộng 5x5
            for z = -2, 2 do
                for x = -2, 2 do
                    PlaceBlock(startCFrame * CFrame.new(x * hX, 0, z * hZ))
                    task.wait(0.1)
                end
            end
        elseif mode == "Pillar" then
            -- Xây Cột: Cao 5 khối
            for y = 0, 4 do
                PlaceBlock(startCFrame * CFrame.new(0, y * hY, 0))
                task.wait(0.1)
            end
        end
    end)
end

