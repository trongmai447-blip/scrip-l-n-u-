local function ApplyEsp(char, color)
    if not char:FindFirstChild("HubEsp") then
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "HubEsp"
        Highlight.FillColor = color
        Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        Highlight.FillTransparency = 0.4
        Highlight.Parent = char
    end
end

RunService.Heartbeat:Connect(function()
    if HackConfig.EspActive then
        pcall(function()
            -- Quét người chơi
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    ApplyEsp(p.Character, Color3.fromRGB(0, 255, 0))
                end
            end
            -- Quét quái vật / Kẻ giết người dựa trên tên thông dụng
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:IsA("Model") and (obj.Name:lower():find("killer") or obj.Name:lower():find("monster") or obj.Name:lower():find("piano")) then
                    ApplyEsp(obj, Color3.fromRGB(255, 0, 0))
                end
            end
        end)
    end
end)

