local function CreateAdjuster(name, targetVar, axis)
    local F = Instance.new("Frame", Scroll)
    F.Size = UDim2.new(1, -10, 0, 30); F.BackgroundTransparency = 1
    
    local L = Instance.new("TextLabel", F)
    L.Size = UDim2.new(0.5, 0, 1, 0); L.BackgroundTransparency = 1
    L.Text = name; L.TextColor3 = Color3.fromRGB(200,200,200); L.TextXAlignment = Enum.TextXAlignment.Left
    
    local BMin = Instance.new("TextButton", F)
    BMin.Size = UDim2.new(0.15, 0, 1, 0); BMin.Position = UDim2.new(0.5, 0, 0, 0)
    BMin.BackgroundColor3 = Color3.fromRGB(60,60,70); BMin.Text = "-"
    BMin.TextColor3 = Color3.fromRGB(255,255,255)
    
    local Val = Instance.new("TextLabel", F)
    Val.Size = UDim2.new(0.2, 0, 1, 0); Val.Position = UDim2.new(0.65, 0, 0, 0)
    Val.BackgroundTransparency = 1; Val.TextColor3 = Color3.fromRGB(0,255,150)
    
    local BPlu = Instance.new("TextButton", F)
    BPlu.Size = UDim2.new(0.15, 0, 1, 0); BPlu.Position = UDim2.new(0.85, 0, 0, 0)
    BPlu.BackgroundColor3 = Color3.fromRGB(60,60,70); BPlu.Text = "+"
    BPlu.TextColor3 = Color3.fromRGB(255,255,255)

    local function Upd() Val.Text = tostring(_G[targetVar][axis]) end
    Upd()

    BMin.MouseButton1Click:Connect(function()
        local c = _G[targetVar]
        if axis=="X" then _G[targetVar]=Vector3.new(c.X-1,c.Y,c.Z) elseif axis=="Y" then _G[targetVar]=Vector3.new(c.X,c.Y-1,c.Z) else _G[targetVar]=Vector3.new(c.X,c.Y,c.Z-1) end
        Upd()
    end)
    BPlu.MouseButton1Click:Connect(function()
        local c = _G[targetVar]
        if axis=="X" then _G[targetVar]=Vector3.new(c.X+1,c.Y,c.Z) elseif axis=="Y" then _G[targetVar]=Vector3.new(c.X,c.Y+1,c.Z) else _G[targetVar]=Vector3.new(c.X,c.Y,c.Z+1) end
        Upd()
    end)
end

