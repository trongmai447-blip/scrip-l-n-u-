-- === VÒNG LẶP AUTO BUILD (BỌC PCALL TỰ PHỤC HỒI) ===
task.spawn(function()
    while true do
        task.wait(_G.BuildDelay) -- Chờ theo tốc độ AI quyết định (tránh văng game)
        if isAutoBuilding and _G.IsReady and _G.TargetRemote then
            local success, err = pcall(function()
                local Char = LocalPlayer.Character
                local Root = Char and Char:FindFirstChild("HumanoidRootPart")
                if Root then
                    local targetPos = Root.Position + (Root.CFrame.LookVector * 6) - Vector3.new(0, 1.5, 0)
                    targetPos = Vector3.new(math.round(targetPos.X), math.round(targetPos.Y), math.round(targetPos.Z))
                    
                    local clonedArgs = ReplaceCoordinatesInArgs(_G.TargetArgs, targetPos)
                    
                    if _G.TargetRemote:IsA("RemoteEvent") then
                        _G.TargetRemote:FireServer(unpack(clonedArgs))
                    elseif _G.TargetRemote:IsA("RemoteFunction") then
                        task.spawn(function()
                            _G.TargetRemote:InvokeServer(unpack(clonedArgs))
                        end)
                    end
                end
            end)
            
            -- NẾU CÓ LỖI XẢY RA KHI ĐẶT KHỐI, BẮT LỖI NGAY!
            if not success then
                F9_DiagnosticAndFix(err, "Trong vòng lặp Auto-Build")
            end
        end
    end
end)

