-- Thuật toán 1: Tìm kiếm Remote thụ động (Không cần tool)
local function AIScanForRemote()
    if AIDetectedRemote and AIDetectedRemote.Parent then return AIDetectedRemote end
    local keywords = {"place", "build", "block", "brick", "create", "voxel", "setcell", "spawn", "click"}
    local targets = {game:GetService("ReplicatedStorage"), game:GetService("JointsService"), workspace, LocalPlayer:FindFirstChildOfClass("PlayerGui")}
    
    for _, storage in ipairs(targets) do
        if storage then
            for _, v in ipairs(storage:GetDescendants()) do
                if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                    for _, kw in ipairs(keywords) do
                        if string.find(string.lower(v.Name), kw) then
                            AIDetectedRemote = v
                            return v
                        end
                    end
                end
            end
        end
    end
    return nil
end

-- Thuật toán 2: Đánh chặn luồng gửi dữ liệu (Hook Metamethod) để phân tích đối số (Arguments)
-- Hệ thống sẽ tự học cấu trúc dữ liệu khi có bất kỳ khối nào được đặt trong server
pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if (method == "FireServer" or method == "fireServer" or method == "InvokeServer") and (self:IsA("RemoteEvent") or self:IsA("RemoteFunction")) then
            local nameLower = string.lower(self.Name)
            local keywords = {"place", "build", "block", "brick", "create", "spawn"}
            local isTarget = false
            for _, kw in ipairs(keywords) do
                if string.find(nameLower, kw) then isTarget = true break end
            end
            
            if isTarget then
                AIDetectedRemote = self
                AICapturedArgs = args
                
                -- Phân tích cấu trúc xem cần những gì:
                if typeof(args[1]) == "Vector3" then
                    AIArgFormat = "Vector3_First"
                elseif typeof(args[1]) == "CFrame" then
                    AIArgFormat = "CFrame_First"
                elseif typeof(args[1]) == "string" then
                    AIArgFormat = "String_First"
                elseif typeof(args[1]) == "table" then
                    AIArgFormat = "Table_Structure"
                end
                
                LogLabel.Text = "🤖 AI Found: " .. self.Name .. " [" .. (AIArgFormat or "Custom") .. "]"
                LogLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
        end
        return oldNamecall(self, ...)
    end)
end)

